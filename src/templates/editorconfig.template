# ==============================================================================
# C# .EDITORCONFIG - OPTIMIZED FOR LLM AGENTS + HUMAN READABILITY
# ==============================================================================
# Goal: code that is explicit, deterministic, and unambiguous -- so both humans
# and AI agents can read, edit, and reason about it reliably.
#
# SEVERITY MODEL (how each rule is enforced):
#   error      -> fails the build. Reserved for hard invariants (e.g. interface
#                 naming).
#   warning    -> shows in the build AND is auto-fixed by plain `dotnet format`.
#                 Used for the non-negotiable, high-value rules (explicit types,
#                 always-braces, file-scoped namespaces, accessibility).
#   suggestion -> does NOT warn the build, but IS auto-applied by
#                 `dotnet format --severity info` (see scripts/format-changed.cs)
#                 and surfaces as IDE hints. Used for modern-C# niceties.
#   silent     -> preference only; never warns, never auto-applied.
#
# To enforce everything (incl. suggestions) run:
#   dotnet run scripts/format-changed.cs          (changed files)
#   dotnet format Admin.slnx --severity info       (whole solution)
# CI check:  dotnet format Admin.slnx --verify-no-changes --severity info
# ==============================================================================

root = true

# ==============================================================================
# ALL FILES
# ==============================================================================
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# ==============================================================================
# C# FILES - CORE FORMATTING
# ==============================================================================
[*.cs]

# --- Indentation & Spacing ---
indent_style = space
indent_size = 4
tab_width = 4

# --- Line Length (optional but recommended) ---
max_line_length = 120

# ==============================================================================
# BRACING & NEWLINES (Allman Style)
# ==============================================================================

# CRITICAL: Always use braces - prevents subtle bugs
csharp_prefer_braces = true:warning

# Allman style: braces on new lines
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# ==============================================================================
# INDENTATION
# ==============================================================================
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = no_change
csharp_indent_block_contents = true
csharp_indent_braces = false

# ==============================================================================
# SPACING
# ==============================================================================
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_parentheses = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_around_binary_operators = before_and_after
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false

# ==============================================================================
# USING DIRECTIVES
# ==============================================================================
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:warning

# ==============================================================================
# MODERN C# FEATURES (C# 9-12)
# ==============================================================================

# File-scoped namespaces (C# 10+)
csharp_style_namespace_declarations = file_scoped:warning

# IDE0130: namespace must match folder structure. Disabled for two reasons:
#  1. Its `dotnet format` code-fix crashes the formatter with
#     "System.NotSupportedException: Changing document properties is not
#     supported" (it tries to apply a document-rename the MSBuild workspace
#     can't apply), aborting the whole run at --severity info.
#  2. Many libraries intentionally use a flat namespace independent of folders.
dotnet_style_namespace_match_folder = false
dotnet_diagnostic.IDE0130.severity = none

# Target-typed new expressions
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion

# Pattern matching
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_not_pattern = true:suggestion
csharp_style_prefer_extended_property_pattern = true:suggestion

# Null checking
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:warning
dotnet_style_coalesce_expression = true:warning
dotnet_style_null_propagation = true:warning
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning

# Expression preferences
csharp_style_inlined_variable_declaration = true:suggestion
csharp_prefer_simple_default_expression = true:suggestion
csharp_style_prefer_index_operator = true:suggestion
csharp_style_prefer_range_operator = true:suggestion
csharp_style_prefer_local_over_anonymous_function = true:suggestion

# Modern using statements
csharp_prefer_simple_using_statement = true:suggestion

# C# 12 Features
# Primary constructors: default ON for DI-style classes. Flip to
# `false:suggestion` if your team prefers explicit constructors with explicit
# field assignments (clearer field<->parameter relationship for LLM agents).
csharp_style_prefer_primary_constructors = true:suggestion
dotnet_style_prefer_collection_expression = true:suggestion
csharp_style_prefer_top_level_statements = true:silent

# Expression-bodied members (use for simple cases)
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_operators = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_indexers = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
csharp_style_expression_bodied_lambdas = true:suggestion
csharp_style_expression_bodied_local_functions = when_on_single_line:suggestion

# ==============================================================================
# VAR USAGE (Explicit Approach - Better for AI & Readability)
# ==============================================================================
# Prefer explicit types for better AI assistance and code clarity
# Use var only when type is immediately obvious from the right-hand side
#
# WHY THIS CHOICE:
# - AI agents (Copilot, Claude, etc.) work better with explicit types
# - No type inference needed = more accurate AI suggestions
# - Better code completion and refactoring support
# - Clearer intent for both humans and AI
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = false:warning
csharp_style_var_elsewhere = false:warning

# ==============================================================================
# CODE STYLE PREFERENCES
# ==============================================================================

# Avoid "this." qualifier unless necessary
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# Use language keywords instead of framework types (int vs Int32)
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# Modifier preferences
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning
dotnet_style_require_accessibility_modifiers = always:warning
dotnet_style_readonly_field = true:warning
csharp_prefer_static_local_function = true:suggestion

# Parentheses preferences
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_operators = never_if_unnecessary:suggestion

# Other preferences
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:silent
dotnet_style_prefer_conditional_expression_over_return = true:silent
dotnet_style_prefer_compound_assignment = true:suggestion
dotnet_style_prefer_simplified_interpolation = true:suggestion
dotnet_style_prefer_simplified_boolean_expressions = true:warning

# ==============================================================================
# NAMING CONVENTIONS (Microsoft Guidelines)
# ==============================================================================

# ------------------------------------------------------------------------------
# INTERFACES - Must start with 'I' (IPascalCase)
# ------------------------------------------------------------------------------
dotnet_naming_rule.interface_should_be_begins_with_i.severity = error
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

# ------------------------------------------------------------------------------
# TYPES - PascalCase (classes, structs, enums, delegates)
# ------------------------------------------------------------------------------
dotnet_naming_rule.types_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum, delegate
dotnet_naming_style.pascal_case.capitalization = pascal_case

# ------------------------------------------------------------------------------
# TYPE PARAMETERS - TPascalCase (generic type parameters)
# ------------------------------------------------------------------------------
dotnet_naming_rule.type_parameters_should_be_t_pascal_case.severity = warning
dotnet_naming_rule.type_parameters_should_be_t_pascal_case.symbols = type_parameters
dotnet_naming_rule.type_parameters_should_be_t_pascal_case.style = t_pascal_case

dotnet_naming_symbols.type_parameters.applicable_kinds = type_parameter
dotnet_naming_style.t_pascal_case.required_prefix = T
dotnet_naming_style.t_pascal_case.capitalization = pascal_case

# ------------------------------------------------------------------------------
# METHODS, PROPERTIES, EVENTS - PascalCase
# ------------------------------------------------------------------------------
dotnet_naming_rule.members_should_be_pascal_case.severity = warning
dotnet_naming_rule.members_should_be_pascal_case.symbols = members
dotnet_naming_rule.members_should_be_pascal_case.style = pascal_case

dotnet_naming_symbols.members.applicable_kinds = method, property, event

# ------------------------------------------------------------------------------
# ASYNC METHODS - Should end with 'Async' (warning allows event handlers)
# ------------------------------------------------------------------------------
dotnet_naming_rule.async_methods_end_in_async.severity = warning
dotnet_naming_rule.async_methods_end_in_async.symbols = async_methods
dotnet_naming_rule.async_methods_end_in_async.style = end_in_async

dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.required_modifiers = async
dotnet_naming_style.end_in_async.required_suffix = Async
dotnet_naming_style.end_in_async.capitalization = pascal_case

# ------------------------------------------------------------------------------
# CONSTANTS & STATIC READONLY - PascalCase
# ------------------------------------------------------------------------------
dotnet_naming_rule.constants_should_be_pascal_case.severity = warning
dotnet_naming_rule.constants_should_be_pascal_case.symbols = constants
dotnet_naming_rule.constants_should_be_pascal_case.style = pascal_case

dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const, static

# ------------------------------------------------------------------------------
# PRIVATE FIELDS - _camelCase
# ------------------------------------------------------------------------------
dotnet_naming_rule.private_fields_should_be_underscore.severity = warning
dotnet_naming_rule.private_fields_should_be_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_underscore.style = underscore_camel

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _

# ------------------------------------------------------------------------------
# PUBLIC/PROTECTED/INTERNAL FIELDS - PascalCase (discouraged but if used)
# ------------------------------------------------------------------------------
dotnet_naming_rule.non_private_fields_should_be_pascal_case.severity = warning
dotnet_naming_rule.non_private_fields_should_be_pascal_case.symbols = non_private_fields
dotnet_naming_rule.non_private_fields_should_be_pascal_case.style = pascal_case

dotnet_naming_symbols.non_private_fields.applicable_kinds = field
dotnet_naming_symbols.non_private_fields.applicable_accessibilities = public, internal, protected, protected_internal, private_protected

# ------------------------------------------------------------------------------
# PARAMETERS & LOCAL VARIABLES - camelCase
# ------------------------------------------------------------------------------
dotnet_naming_rule.locals_should_be_camel_case.severity = suggestion
dotnet_naming_rule.locals_should_be_camel_case.symbols = locals_and_params
dotnet_naming_rule.locals_should_be_camel_case.style = camel_case

dotnet_naming_symbols.locals_and_params.applicable_kinds = parameter, local
dotnet_naming_style.camel_case.capitalization = camel_case

# ------------------------------------------------------------------------------
# LOCAL FUNCTIONS - PascalCase
# ------------------------------------------------------------------------------
dotnet_naming_rule.local_functions_should_be_pascal_case.severity = suggestion
dotnet_naming_rule.local_functions_should_be_pascal_case.symbols = local_functions
dotnet_naming_rule.local_functions_should_be_pascal_case.style = pascal_case

dotnet_naming_symbols.local_functions.applicable_kinds = local_function

# ==============================================================================
# CODE QUALITY RULES
# ==============================================================================

# CA1031: Do not catch general exception types
dotnet_diagnostic.CA1031.severity = suggestion

# CA1062: Validate arguments of public methods
dotnet_diagnostic.CA1062.severity = suggestion

# CA1303: Do not pass literals as localized parameters
dotnet_diagnostic.CA1303.severity = silent

# CA1716: Identifiers should not match keywords
dotnet_diagnostic.CA1716.severity = warning

# CA2007: Consider calling ConfigureAwait on the awaited task.
# silent (not suggestion): this is an app, not a library — ConfigureAwait(false)
# is unnecessary here, and at suggestion the `--severity info` formatter would
# inject it across every await. Kept off to avoid that churn.
dotnet_diagnostic.CA2007.severity = silent

# IDE0001: Simplify name
dotnet_diagnostic.IDE0001.severity = warning

# IDE0004: Remove unnecessary cast
dotnet_diagnostic.IDE0004.severity = warning

# IDE0005: Remove unnecessary using directives
dotnet_diagnostic.IDE0005.severity = warning

# IDE0051: Remove unused private member
dotnet_diagnostic.IDE0051.severity = warning

# IDE0052: Remove unread private member
dotnet_diagnostic.IDE0052.severity = warning

# IDE0055: Formatting rule
dotnet_diagnostic.IDE0055.severity = warning

# Unused parameters
dotnet_code_quality_unused_parameters = all:warning
dotnet_remove_unnecessary_suppression_exclusions = none

# ==============================================================================
# PERFORMANCE & MODERN C# (Nice-to-haves)
# ==============================================================================

# C# 11 UTF-8 string literals
csharp_style_prefer_utf8_string_literals = true:suggestion

# Encourage immutable structs
csharp_style_prefer_readonly_struct = true:suggestion
csharp_style_prefer_readonly_struct_member = true:suggestion

# CA1848: Use LoggerMessage delegates for high-performance logging
dotnet_diagnostic.CA1848.severity = suggestion

# CA1860: Prefer Length/Count > 0 over Any()
dotnet_diagnostic.CA1860.severity = suggestion

# ==============================================================================
# STYLECOP ANALYZERS
# ==============================================================================
# Package referenced in Directory.Build.props (applies to src/ + aspire/, not
# the isolated Nuke build project).
#
# Strategy: .editorconfig + dotnet format own formatting / spacing / naming.
# StyleCop is used ONLY for the structural rules it uniquely adds (member
# ordering). Everything that overlaps or conflicts with our conventions is
# turned off below so the build isn't flooded with noise.

# --- Turn StyleCop OFF by category, then opt back in ---------------------------
# Spacing / Readability / Naming / Maintainability / Layout / Documentation /
# Special rules all overlap with dotnet format + our conventions above, so we
# disable them wholesale to avoid a flood of duplicate/conflicting warnings.
# Per-rule settings below override these category defaults.
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.SpacingRules.severity = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.ReadabilityRules.severity = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.OrderingRules.severity = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.NamingRules.severity = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.MaintainabilityRules.severity = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.LayoutRules.severity = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.DocumentationRules.severity = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.SpecialRules.severity = none
dotnet_diagnostic.SA0001.severity = none   # XML comment analysis (docs not required)

# --- Enable ONLY member ordering: the reason we use StyleCop -------------------
# Order: Constants -> Static Fields -> Fields -> Constructors -> Properties -> Methods
# Within each group: public -> internal -> protected -> private.
# NOTE: These are build-visible guardrails. Run scripts/format-changed.cs before
# committing changed C# files so cleanupcode can apply the matching reorder
# profile before dotnet format runs.
dotnet_diagnostic.SA1201.severity = warning      # Elements in the correct order
dotnet_diagnostic.SA1202.severity = warning      # Ordered by access (public first)
dotnet_diagnostic.SA1203.severity = warning      # Constants before fields
# SA1204 (static before instance) is a suggestion, not a warning: the cleanupcode
# reorder layout sorts access-primary and ReSharper's reorderer can only sort
# instance-first within an access group, so static-first within a group is not
# auto-enforced. Left as an advisory hint for agents/devs.
dotnet_diagnostic.SA1204.severity = suggestion   # Static before instance (advisory)
dotnet_diagnostic.SA1214.severity = suggestion   # Readonly fields before non-readonly
dotnet_diagnostic.SA1212.severity = warning      # get before set (has code fix)
dotnet_diagnostic.SA1213.severity = warning      # add before remove (has code fix)

# ==============================================================================
# PROJECT-SPECIFIC FILES
# ==============================================================================

# XML project files
[*.{csproj,vbproj,vcxproj,vcxproj.filters,proj,projitems,shproj}]
indent_size = 2

# XML config files
[*.{props,targets,ruleset,config,nuspec,resx,vsixmanifest,vsct}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Shell scripts
[*.sh]
end_of_line = lf

# Batch files
[*.{cmd,bat}]
end_of_line = crlf

# ==============================================================================
# BLAZOR CODE-BEHIND (must stay LAST so these keys win for *.razor.cs)
# ==============================================================================
# C# analyzers/fixers only see the .cs file, never the paired .razor markup that
# shares the same partial class. So members referenced from markup look unused /
# freely renamable / mergeable, and "fixing" them silently breaks the build.
# Disable the three transformations that cross that markup boundary.
[*.razor.cs]
# "Use auto property" merges a backing field into the property (and rewrites it
# to the `field` keyword), dropping fields that markup still binds to.
dotnet_style_prefer_auto_properties = false
dotnet_diagnostic.IDE0032.severity = none
# "Remove unused/unread private member" — markup-only-used members look unused.
dotnet_diagnostic.IDE0051.severity = none
dotnet_diagnostic.IDE0052.severity = none
# Naming rules (e.g. private field -> _underscore) would rename members that
# markup binds by name (@CreateRequest, @paymentEntryTypeOptions, ...). A rename
# can't be seen across the .razor boundary, so suppress auto-rename here.
dotnet_diagnostic.IDE1006.severity = none
